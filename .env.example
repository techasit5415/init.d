# PocketBase endpoint the SvelteKit server connects to. May be the LAN
# address or a public domain that proxies back to PB.
POCKETBASE_URL=https://db.cskmitl.com

# Public mirror consumed by the SvelteKit client bundle and used by
# scripts to update the PB `url` setting. Must be the URL the user
# actually sees in their browser — PB embeds this in OAuth redirects,
# so private IPs (192.168.x, 10.x, localhost) will be rejected by
# providers like Google.
VITE_POCKETBASE_URL=https://db.cskmitl.com

# PB superuser (admin) — used by setup scripts to call the admin API
# (creating collections, registering OAuth providers, seeding users).
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# Optional: seed an admin user in the `users` collection. The script
# creates the `user_type` row if missing and links the new user to it.
# PB_USER_USERNAME=
# PB_USER_PASSWORD=
# PB_USER_EMAIL=
# PB_USER_NAME=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Create OAuth 2.0 Client ID, type "Web application", with this
# authorized redirect URI:
#   ${VITE_POCKETBASE_URL}/api/oauth2-redirect
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://db.cskmitl.com/api/oauth2-redirect
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
